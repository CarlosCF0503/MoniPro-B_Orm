// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Enums (Status e Tipos)
enum TipoUsuario {
  aluno
  monitor
}

enum StatusMonitoria {
  ativa
  pendente
  realizada
  concluida
  cancelada
}

enum StatusAgendamento {
  pendente
  confirmado
  cancelado
}

// Tabelas
model Usuario {
  id            Int         @id @default(autoincrement())
  nome_completo String
  email         String      @unique
  senha         String
  tipo_usuario  TipoUsuario
  matricula     Int         @unique

  // Relacionamentos: O Prisma entende quem cria vagas e quem se inscreve nelas
  monitorias_criadas MonitoriaService[]   @relation("MonitorParaMonitoria")
  meus_agendamentos  Agendamento[] @relation("AlunoParaAgendamento")

  @@map("usuarios") // Nome exato da tabela no Postgres
}

model Disciplina {
  id         Int         @id @default(autoincrement())
  nome       String
  monitorias MonitoriaService[]

  @@map("disciplinas")
}

model MonitoriaService {
  id            Int             @id @default(autoincrement())
  horario       DateTime
  descricao     String?
  local         String
  status        StatusMonitoria @default(ativa)

  // Chaves Estrangeiras
  id_monitor    Int
  monitor       Usuario         @relation("MonitorParaMonitoria", fields: [id_monitor], references: [id])

  id_disciplina Int
  disciplina    Disciplina      @relation(fields: [id_disciplina], references: [id])

  inscricoes    Agendamento[]

  @@map("monitorias")
}

model Agendamento {
  id           Int               @id @default(autoincrement())
  data_hora    DateTime
  status       StatusAgendamento @default(pendente)

  // Chaves Estrangeiras
  id_monitoria Int
  monitoria    MonitoriaService         @relation(fields: [id_monitoria], references: [id])

  id_aluno     Int
  aluno        Usuario           @relation("AlunoParaAgendamento", fields: [id_aluno], references: [id])

  @@map("agendamentos")
}